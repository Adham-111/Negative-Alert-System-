    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst updatedItems = items.map((item) => {\n  const now = new Date();\n  \n  // استخراج اليوم والشهر والسنة مع إضافة صفر جهة اليسار للأرقام الفردية\n  const day = String(now.getDate()).padStart(2, '0');\n  const month = String(now.getMonth() + 1).padStart(2, '0'); // الأشهر تبدأ من 0 في JS\n  const year = now.getFullYear();\n\n  // تنسيق التاريخ بالصيغة المطلوبة\n  item.json.submissionDate = `${day}-${month}-${year}`;\n  \n  return item;\n});\n\nreturn updatedItems;\n"
      },
